# =========================================
# REQUIRED VARIABLES

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Register at https://github.com/settings/developers
# Callback URL must be: http://localhost:1111/auth/callback

# === Session & Encryption Secrets
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production


# ==========================================
# OPTIONAL Variables

# If set here, the backend will use it by default
# and the user won't have to supply one.
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_KEY=your_openrouter_api_key

# Only needed if running backend outside Docker (Docker provides a default)
# DATABASE_URL=postgresql+asyncpg://samuel:samuel_dev_only@localhost:5432/samuel

# LOG_LEVEL=INFO

# DEBUG_DIR=notes/samuel/debug

# === Security (Optional — set True in production) ===
# SECURE_COOKIE=False
