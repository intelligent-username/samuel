# Duplicate this .env.example file, name it .env, and assign the variables as appropriate.
# =========================================
# REQUIRED VARIABLES

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Register at https://github.com/settings/developers
# Callback URL must be: http://localhost:3000/auth/callback

# === Session & Encryption Secrets ===
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production


# =========================================
# OPTIONAL VARIABLES

# Default OpenRouter API key used if user hasn't set one via the dashboard.
# Users can also supply their own key through the UI.
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Database — only needed if running backend outside Docker
# DATABASE_URL=postgresql+asyncpg://samuel:samuel_dev_only@localhost:5432/samuel

# Logging level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Debug output directory for skill chain prompt/response files
# DEBUG_DIR=/tmp/samuel/debug

# How many hours to retain debug files before cleanup
# DEBUG_RETENTION_HOURS=24

# Security — set to True in production (requires HTTPS)
# SECURE_COOKIE=False
